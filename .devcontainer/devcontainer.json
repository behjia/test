//V3:
{
    "name": "AutoNPU EDA Environment",
    "image": "mcr.microsoft.com/devcontainers/python:3.10-bookworm",
    "runArgs": [
        "--shm-size=2g"
    ],
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "version": "latest",
            "enableNonRootDocker": "true",
            "moby": "false"
        }
    },
    "postCreateCommand": "sudo apt-get update && sudo apt-get install -y build-essential make g++ graphviz gtkwave tcl tcllib tk iverilog yosys ngspice magic python3-venv git-lfs && pip install --upgrade pip && pip install cocotb==1.7.2 ray pytest python-dotenv anthropic && (if [ ! -d 'OpenLane' ]; then git clone --depth 1 https://github.com/The-OpenROAD-Project/OpenLane.git && cd OpenLane && make; fi)",
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python"
            },
            "extensions": [
                "GitHub.copilot",
                "GitHub.copilot-chat",
                "ms-python.python",
                "mshr-h.VerilogHDL",
                "eamodio.gitlens"
            ]
        }
    }
}
