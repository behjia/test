import cocotb
from cocotb.clock import Clock
from cocotb.triggers import RisingEdge, Timer
import os
import sys
from pathlib import Path

# Add current directory to path so we can import dynamically generated files
sys.path.append(os.path.dirname(os.path.abspath(__file__)))

if os.environ.get("SIM", "verilator") == "verilator":
    os.environ["COCOTB_TRACING"] = "1"

@cocotb.test()
async def {{ module_name }}_integration_test(dut):
    """Top-level CPU integration smoke test: run the SoC for 50 clock cycles."""

    if hasattr(dut, "clk"):
        cocotb.start_soon(Clock(dut.clk, 10, units="ns").start())
    if hasattr(dut, "rst_n"):
        dut.rst_n.value = 0
        await Timer(20, units="ns")
        dut.rst_n.value = 1
    elif hasattr(dut, "rst"):
        dut.rst.value = 1
        await Timer(20, units="ns")
        dut.rst.value = 0

    for cycle in range(50):
        await RisingEdge(dut.clk)
        await Timer(1, units="ns")

    dut._log.info("✅ Top-Level CPU Integration: 50 Clock Cycles executed without deadlock.")
