import cocotb
from cocotb.triggers import Timer, RisingEdge
{% if is_sequential %}
from cocotb.clock import Clock
{% endif %}

@cocotb.test()
async def {{ module_name }}_basic_test(dut):
    """Auto-generated testbench for the {{ module_name }} module."""
    
    {% if is_sequential %}
    # Auto-start clock if sequential
    if hasattr(dut, 'clk'):
        cocotb.start_soon(Clock(dut.clk, 10, unit="ns").start())
    
    # Standard Reset Sequence
    if hasattr(dut, 'rst_n'):
        dut.rst_n.value = 0
        await Timer(20, unit="ns")
        dut.rst_n.value = 1
        await RisingEdge(dut.clk)
    {% endif %}

    {% if test_vectors %}
    test_vectors = [
        {% for vec in test_vectors %}
        ({{ vec | join(', ') }}),
        {% endfor %}
    ]
    for {% for input in inputs %}{{ input.name }}_val, {% endfor %}expected in test_vectors:
        {% for input in inputs %}
        if hasattr(dut, '{{ input.name }}') and 'clk' not in '{{ input.name }}':
            dut.{{ input.name }}.value = {{ input.name }}_val
        {% endfor %}
        
        {% if is_sequential %}
        await RisingEdge(dut.clk)
        {% else %}
        await Timer(1, unit="ns")
        {% endif %}
        
        result = int(dut.{{ output_name }}.value)
        assert result == expected, f"FAIL: result={result} (expected {expected})"
        dut._log.info(f"PASS: result={result}")
        
    {% else %}
    # Fallback simulation to prove compilation success
    {% for input in inputs %}
    if hasattr(dut, '{{ input.name }}') and 'clk' not in '{{ input.name }}':
        dut.{{ input.name }}.value = 0
    {% endfor %}
    
    {% if is_sequential %}
    for _ in range(5):
        await RisingEdge(dut.clk)
    {% else %}
    await Timer(10, unit="ns")
    {% endif %}
    
    result = int(dut.{{ output_name }}.value)
    dut._log.info(f"Fallback simulation complete — {{ output_name }} = {result}")
    {% endif %}
