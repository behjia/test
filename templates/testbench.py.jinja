# ==============================================================================
def get_directed_random(width):
    """Generates standard randoms PLUS critical hardware corner cases."""
    max_val = (1 << width) - 1
    corners = [
        0,                  # All zeros
        max_val,            # All ones (Max Value)
        max_val - 1,        # Off-by-one edge case
        1,                  # Lowest active bit
        int("1010"*16, 2) & max_val,  # Alternating 1010
        int("0101"*16, 2) & max_val   # Alternating 0101
    ]
    # 30% chance of a corner case, 70% chance of pure random
    if random.random() < 0.3:
        return random.choice(corners)
    return random.randint(0, max_val)

